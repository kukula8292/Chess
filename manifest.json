{
  "manifest_version": 3,
  "name": "Chess Helper AI",
  "version": "1.0",
  "description": "Unlimited chess analysis using Stockfish",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://lichess.org/*", "*://chess.com/*"],
      "js": ["stockfish.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["stockfish.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
